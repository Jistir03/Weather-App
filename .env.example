# OpenWeatherMap API key — required for all weather data
# 1. Sign up at https://openweathermap.org/api (free tier)
# 2. Copy your API key from the dashboard
# 3. Create .env.local in this directory  <-- IMPORTANT: use .env.local, NOT .env
#    (.env is tracked by git; .env.local is gitignored and keeps your key safe)
# 4. Add: VITE_OWM_API_KEY=your_actual_key

VITE_OWM_API_KEY=your_key_here
